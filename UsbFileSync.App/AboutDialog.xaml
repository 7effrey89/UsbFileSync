<Window x:Class="UsbFileSync.App.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About UsbFileSync"
        Width="430"
        Height="250"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="UsbFileSync" FontSize="20" FontWeight="SemiBold" />
        <TextBlock x:Name="VersionTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="#616161" />
        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Text="UsbFileSync is a Windows desktop file synchronization tool for preview-first syncing workflows."
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="3" Margin="0,14,0,0" TextWrapping="Wrap">
            <Run Text="GitHub: " />
            <Hyperlink Click="OnRepositoryLinkClicked">
                <Run x:Name="RepositoryLinkText" />
            </Hyperlink>
        </TextBlock>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="90" Content="Close" IsDefault="True" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
