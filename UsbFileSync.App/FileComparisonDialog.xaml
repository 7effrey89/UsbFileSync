<Window x:Class="UsbFileSync.App.FileComparisonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Comparison"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F3">
    <Window.Resources>
        <Style x:Key="ComparisonCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E5E5E5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="PathLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#0B57D0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   TextWrapping="Wrap"
                                   TextDecorations="Underline"
                                   Foreground="{TemplateBinding Foreground}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Compare source and destination" FontSize="22" FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ComparisonCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SourceSideLabelTextBlock" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="SourceFileNameTextBlock" Grid.Row="1" Margin="0,8,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <Grid x:Name="SourceMetadataGrid" Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SourceSizeTextBlock" Foreground="#616161" />
                        <TextBlock x:Name="SourceDateTextBlock" Grid.Column="1" Foreground="#616161" />
                    </Grid>
                    <Border x:Name="SourcePreviewBorder" Grid.Row="3" Margin="0,12,0,0" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="4" Background="#FAFAFA" Padding="12">
                        <Grid>
                            <ScrollViewer x:Name="SourceTextPreviewViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBlock x:Name="SourcePreviewTextBlock"
                                           Background="Transparent"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           TextWrapping="Wrap"
                                           FontFamily="Consolas" />
                            </ScrollViewer>
                            <ScrollViewer x:Name="SourceImagePreviewViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Visibility="Collapsed">
                                <Image x:Name="SourcePreviewImage" Stretch="Uniform" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="SourceEmptyStateTextBlock" Grid.Row="3" Margin="0,12,0,0" FontWeight="SemiBold" Visibility="Collapsed" />
                    <StackPanel x:Name="SourcePathPanel" Grid.Row="4" Margin="0,12,0,0">
                        <TextBlock Text="Full path:" />
                        <Button x:Name="SourcePathButton" Style="{StaticResource PathLinkButtonStyle}" Click="OnOpenPathClicked" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ComparisonCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="DestinationSideLabelTextBlock" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="DestinationFileNameTextBlock" Grid.Row="1" Margin="0,8,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <Grid x:Name="DestinationMetadataGrid" Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DestinationSizeTextBlock" Foreground="#616161" />
                        <TextBlock x:Name="DestinationDateTextBlock" Grid.Column="1" Foreground="#616161" />
                    </Grid>
                    <Border x:Name="DestinationPreviewBorder" Grid.Row="3" Margin="0,12,0,0" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="4" Background="#FAFAFA" Padding="12">
                        <Grid>
                            <ScrollViewer x:Name="DestinationTextPreviewViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBlock x:Name="DestinationPreviewTextBlock"
                                           Background="Transparent"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           TextWrapping="Wrap"
                                           FontFamily="Consolas" />
                            </ScrollViewer>
                            <ScrollViewer x:Name="DestinationImagePreviewViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Visibility="Collapsed">
                                <Image x:Name="DestinationPreviewImage" Stretch="Uniform" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="DestinationEmptyStateTextBlock" Grid.Row="3" Margin="0,12,0,0" FontWeight="SemiBold" Visibility="Collapsed" />
                    <StackPanel x:Name="DestinationPathPanel" Grid.Row="4" Margin="0,12,0,0">
                        <TextBlock Text="Full path:" />
                        <Button x:Name="DestinationPathButton" Style="{StaticResource PathLinkButtonStyle}" Click="OnOpenPathClicked" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="100" Content="Close" IsCancel="True" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>