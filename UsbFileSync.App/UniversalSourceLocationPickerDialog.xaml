<Window x:Class="UsbFileSync.App.UniversalSourceLocationPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Source Folder"
        Width="880"
        Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#F3F3F3"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <DataTemplate x:Key="RootItemTemplate">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{Binding IconSource}" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding DisplayText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="BrowserEntryTemplate">
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="{Binding IconSource}" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding DisplayText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Margin="10,0,0,0" Text="{Binding SecondaryText}" Foreground="#757575" VerticalAlignment="Center" />
                </Grid>
            </DataTemplate>

            <Style x:Key="NonSelectableListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
            </Style>
        </Grid.Resources>

        <TextBlock x:Name="DialogHeadingTextBlock" Text="Browse folders across supported volumes" FontSize="18" FontWeight="SemiBold" />
        <TextBlock x:Name="DialogDescriptionTextBlock" Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="#616161"
               Text="Select a root on the left, browse folders on the right, and choose the current folder."
                   TextWrapping="Wrap" />

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Text="Available roots" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Browse" FontSize="14" FontWeight="SemiBold" />

            <Border Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" BorderBrush="#D0D0D0" BorderThickness="1" Background="White" CornerRadius="8">
                <ListBox x:Name="RootsListBox"
                         BorderThickness="0"
                         ItemTemplate="{StaticResource RootItemTemplate}"
                         SelectionChanged="OnRootSelectionChanged" />
            </Border>

            <Grid Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="CurrentFolderTextBox"
                             VerticalContentAlignment="Center"
                             Margin="0,0,10,0"
                             KeyDown="OnCurrentFolderTextBoxKeyDown" />
                    <Button Grid.Column="1" Width="44" Margin="0,0,10,0" Content="-&gt;" Click="OnNavigateToPathClicked" />
                    <Button Grid.Column="2" Width="90" Content="Up" Click="OnUpClicked" />
                </Grid>

                <Border Grid.Row="1" Margin="0,10,0,0" Padding="10,8" BorderBrush="#D0D0D0" BorderThickness="1" Background="White" CornerRadius="8">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" />
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2" Margin="0,10,0,0" BorderBrush="#D0D0D0" BorderThickness="1" Background="White" CornerRadius="8">
                    <DockPanel>
                        <TextBlock x:Name="FolderStatusTextBlock"
                                   DockPanel.Dock="Bottom"
                                   Margin="12,6,12,10"
                                   Foreground="#616161"
                                   Text="Select a root to browse folders."
                                   TextWrapping="Wrap" />
                        <Grid Margin="12,12,12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0" Text="Folders" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Files" FontWeight="SemiBold" />

                            <Border Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" BorderBrush="#E1E1E1" BorderThickness="1" CornerRadius="6">
                                <ListBox x:Name="FoldersListBox"
                                         BorderThickness="0"
                                         ItemTemplate="{StaticResource BrowserEntryTemplate}"
                                         MouseDoubleClick="OnFolderDoubleClick" />
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" BorderBrush="#E1E1E1" BorderThickness="1" CornerRadius="6">
                                <ListBox x:Name="FilesListBox"
                                         Focusable="False"
                                         IsTabStop="False"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource NonSelectableListBoxItemStyle}"
                                         ItemTemplate="{StaticResource BrowserEntryTemplate}" />
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="90" Margin="0,0,10,0" Content="Open" Click="OnOpenFolderClicked" />
            <Button Width="140" Margin="0,0,10,0" Content="Select This Folder" IsDefault="True" Click="OnSelectCurrentFolderClicked" />
            <Button Width="90" Content="Cancel" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>