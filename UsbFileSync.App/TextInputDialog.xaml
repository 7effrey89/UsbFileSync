<Window x:Class="UsbFileSync.App.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usb File Sync"
        Height="200"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F3F3"
        FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptTextBlock"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#1F1F1F"
                   TextWrapping="Wrap" />
        <TextBlock x:Name="DescriptionTextBlock"
                   Grid.Row="1"
                   Margin="0,10,0,0"
                   Foreground="#616161"
                   TextWrapping="Wrap" />
        <TextBox x:Name="ValueTextBox"
                 Grid.Row="2"
                 Margin="0,14,0,0"
                 Padding="10,7"
                 BorderBrush="#CFCFCF" />
        <StackPanel Grid.Row="3"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="92"
                    Margin="0,0,10,0"
                    Padding="14,8"
                    IsDefault="True"
                    Click="OnOkClicked"
                    Content="OK" />
            <Button Width="92"
                    Padding="14,8"
                    IsCancel="True"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>
