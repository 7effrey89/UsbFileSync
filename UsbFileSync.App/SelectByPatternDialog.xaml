<Window x:Class="UsbFileSync.App.SelectByPatternDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select By Pattern"
        Width="420"
        Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Select items by keyword" FontSize="16" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   Text="Matches use contains logic, so typing keyword matches any file entry containing keyword."
                   Foreground="#616161"
                   TextWrapping="Wrap" />
        <TextBox x:Name="PatternTextBox"
                 Grid.Row="2"
                 Margin="0,12,0,0"
                 VerticalContentAlignment="Center" />

        <GroupBox Grid.Row="3" Header="Match against" Margin="0,14,0,0" MinHeight="108">
            <StackPanel Margin="10,8,10,10">
                <RadioButton x:Name="FileNameRadioButton" Content="File name" IsChecked="True" Margin="0,0,0,6" />
                <RadioButton x:Name="FileFolderRadioButton" Content="File folder" Margin="0,0,0,6" />
                <RadioButton x:Name="FullPathRadioButton" Content="Full path" />
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,4">
            <Button Width="90" Margin="0,0,10,0" Content="Cancel" IsCancel="True" />
            <Button Width="90" Content="OK" IsDefault="True" Click="OnOkClicked" />
        </StackPanel>
    </Grid>
</Window>