<Window x:Class="UsbFileSync.App.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Application Settings"
        Width="1080"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F3F3F3">
    <DockPanel Margin="20" LastChildFill="True">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="90" Margin="0,0,10,0" Content="Cancel" IsCancel="True" />
            <Button Width="90" Content="Save" IsDefault="True" Click="OnSaveClicked" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel>
                <TextBlock Text="Parallel copies" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Margin="0,8,0,0" Text="Choose how many file copy operations can run at the same time." TextWrapping="Wrap" Foreground="#616161" />
                <StackPanel Margin="0,14,0,0">
                    <TextBox x:Name="ParallelCopyCountTextBox"
                             Width="120"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Enter 0 to let UsbFileSync automatically assess and use the best amount of parallelism while syncing."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Mac HFS+ source filtering" FontSize="15" FontWeight="SemiBold" />
                    <CheckBox x:Name="HideMacOsSystemFilesCheckBox"
                              Margin="0,10,0,0"
                              Content="Hide macOS system files in HFS+ preview and sync planning" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Filters common HFS+ metadata entries such as .Spotlight-V100, .fseventsd, .journal, and HFS+ Private Data from the sync view."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Path exclusion patterns" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Exclude heavy folders from preview analysis and sync planning by entering one pattern per line. Single-segment patterns such as node_modules, .venv, bin, and obj match anywhere in the tree. You can also enter relative multi-segment patterns such as src/generated or cache/*/tmp."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <TextBox x:Name="ExcludedPathPatternsTextBox"
                             Margin="0,12,0,0"
                             Height="120"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Leave this blank to include every path. These exclusions apply to both preview analysis and synchronization planning."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Image rename pattern" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Choose the filename layout used by Drive Tools &gt; Image Rename. The optional city suffix is skipped when location metadata is unavailable."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <ComboBox x:Name="ImageRenamePatternComboBox"
                              Margin="0,12,0,0"
                              Width="420"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Kind" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Image rename camera filename scope" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="UsbFileSync only renames common camera-style filenames. Choose the default camera masks to include, then add your own masks below if needed. Use ? for one character and * for multiple characters."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <ItemsControl x:Name="ImageRenamePatternOptionsItemsControl" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,4,0,0"
                                          Content="{Binding Label}"
                                          IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,12,0,0"
                               Text="Custom filename masks"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Add one custom mask per row, then check the rows you want Image Rename to use."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <ItemsControl x:Name="ImageRenameCustomPatternItemsControl" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="2"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="4"
                                            Width="74"
                                            Content="Remove"
                                            Tag="{Binding}"
                                            Click="OnRemoveImageRenameCustomPatternClicked" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Width="170"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Content="Add custom mask"
                            Click="OnAddImageRenameCustomPatternClicked" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Example custom masks: GOPR????, MVI_????, or VID_*."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Image rename file formats" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Choose which file extensions Image Rename should consider. Defaults target common camera photo and video formats."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <ItemsControl x:Name="ImageRenameExtensionOptionsItemsControl" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,4,0,0"
                                          Content="{Binding Label}"
                                          IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,12,0,0"
                               Text="Custom file extensions"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Add one custom extension per row, then check the rows you want Image Rename to include."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <ItemsControl x:Name="ImageRenameCustomExtensionItemsControl" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="2"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="4"
                                            Width="74"
                                            Content="Remove"
                                            Tag="{Binding}"
                                            Click="OnRemoveImageRenameCustomExtensionClicked" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Width="185"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Left"
                            Content="Add custom extension"
                            Click="OnAddImageRenameCustomExtensionClicked" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Enter custom extensions such as .orf or .arw."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Cloud provider credentials" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="UsbFileSync uses built-in provider credentials by default. Turn on the advanced setting below if you want to override those defaults with your own provider app registrations."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <CheckBox x:Name="UseCustomProviderCredentialsCheckBox"
                              Margin="0,10,0,0"
                              Content="Use custom provider credentials (advanced)" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Add one row per cloud account. Use the alias column to label accounts clearly. OneDrive always uses the fixed 'common' tenant in UsbFileSync settings."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <DataGrid x:Name="CloudProviderRegistrationsDataGrid"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              IsEnabled="{Binding IsChecked, ElementName=UseCustomProviderCredentialsCheckBox}"
                              Height="230">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Provider"
                                                    SelectedItemBinding="{Binding Provider, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="145" />
                            <DataGridTextColumn Header="Alias"
                                                Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}"
                                                Width="150" />
                            <DataGridTextColumn Header="OAuth client ID / App key"
                                                Binding="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                                                Width="2.1*" />
                            <DataGridTextColumn Header="Client secret / App secret"
                                                Binding="{Binding ClientSecret, UpdateSourceTrigger=PropertyChanged}"
                                                Width="1.3*" />
                            <DataGridTextColumn Header="Tenant ID (OneDrive fixed)"
                                                Binding="{Binding TenantId}"
                                                IsReadOnly="True"
                                                Width="150" />
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding ConnectionStatusText}"
                                                IsReadOnly="True"
                                                Width="1.2*" />
                            <DataGridTemplateColumn Header="Test" Width="85">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="64"
                                                Content="Test"
                                                Click="OnTestCloudProviderConnectionClicked" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Width="110" Content="Add Account" Click="OnAddCloudAccountClicked" />
                        <Button Width="130" Margin="10,0,0,0" Content="Remove Selected" Click="OnRemoveCloudAccountClicked" />
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0"
                               Text="Dropbox uses the app key in the client ID column and can optionally use an app secret. Google Drive can also store an optional client secret if your Google OAuth client requires one during token exchange. OneDrive uses a public desktop client flow and does not use a client secret here."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                </StackPanel>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Text="Preview providers" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Margin="0,8,0,0"
                               Text="Choose which preview provider should handle each file extension. Supported providers currently are Text, Image, PDF, Media, and Unsupported."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <DataGrid x:Name="PreviewProviderMappingsDataGrid"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              Height="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Extension" Binding="{Binding Extension, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                            <DataGridComboBoxColumn Header="Preview provider"
                                                    SelectedItemBinding="{Binding ProviderKind, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Width="90" Content="Add" Click="OnAddMappingClicked" />
                        <Button Width="90" Margin="10,0,0,0" Content="Remove" Click="OnRemoveMappingClicked" />
                        <Button Width="130" Margin="10,0,0,0" Content="Restore defaults" Click="OnRestoreDefaultsClicked" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
