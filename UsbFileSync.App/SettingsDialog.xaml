<Window x:Class="UsbFileSync.App.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Application Settings"
        Width="360"
    Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Parallel copies" FontSize="15" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Choose how many file copy operations can run at the same time." TextWrapping="Wrap" Foreground="#616161" />
        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBox x:Name="ParallelCopyCountTextBox"
                     Width="120"
                     HorizontalAlignment="Left"
                     VerticalContentAlignment="Center" />
            <TextBlock Margin="0,8,0,0"
                       Text="Enter 0 to let UsbFileSync automatically adjust parallel copy operations while syncing."
                       TextWrapping="Wrap"
                       Foreground="#616161" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="90" Margin="0,0,10,0" Content="Cancel" IsCancel="True" />
            <Button Width="90" Content="Save" IsDefault="True" Click="OnSaveClicked" />
        </StackPanel>
    </Grid>
</Window>
