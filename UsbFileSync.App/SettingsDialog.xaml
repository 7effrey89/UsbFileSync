<Window x:Class="UsbFileSync.App.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Application Settings"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl>
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Parallel copies" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Choose how many file copy operations can run at the same time." TextWrapping="Wrap" Foreground="#616161" />
                        <StackPanel Grid.Row="2" Margin="0,14,0,0">
                            <TextBox x:Name="ParallelCopyCountTextBox"
                                     Width="120"
                                     HorizontalAlignment="Left"
                                     VerticalContentAlignment="Center" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Enter 0 to let UsbFileSync automatically assess and use the best amount of parallelism while syncing."
                                       TextWrapping="Wrap"
                                       Foreground="#616161" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,18,0,0">
                            <TextBlock Text="Mac HFS+ source filtering" FontSize="15" FontWeight="SemiBold" />
                            <CheckBox x:Name="HideMacOsSystemFilesCheckBox"
                                      Margin="0,10,0,0"
                                      Content="Hide macOS system files in HFS+ preview and sync planning" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Filters common HFS+ metadata entries such as .Spotlight-V100, .fseventsd, .journal, and HFS+ Private Data from the sync view."
                                       TextWrapping="Wrap"
                                       Foreground="#616161" />
                        </StackPanel>

                        <Grid Grid.Row="4" Margin="0,18,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Preview providers" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       Text="Choose which preview provider should handle each file extension. Supported providers currently are Text, Image, PDF, Media, Office, and Unsupported."
                                       TextWrapping="Wrap"
                                       Foreground="#616161" />
                            <DataGrid x:Name="PreviewProviderMappingsDataGrid"
                                      Grid.Row="2"
                                      Margin="0,12,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      SelectionMode="Single"
                                      MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Extension" Binding="{Binding Extension, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                    <DataGridComboBoxColumn Header="Preview provider"
                                                            SelectedItemBinding="{Binding ProviderKind, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Width="90" Content="Add" Click="OnAddMappingClicked" />
                                <Button Width="90" Margin="10,0,0,0" Content="Remove" Click="OnRemoveMappingClicked" />
                                <Button Width="130" Margin="10,0,0,0" Content="Restore defaults" Click="OnRestoreDefaultsClicked" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Cloud accounts">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Registered cloud account roots" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Text="Register each Google Drive, Dropbox, or OneDrive account you want to browse in UsbFileSync. Point each row at the local synced folder for that login so the account appears in the source and destination pickers like a drive root."
                               TextWrapping="Wrap"
                               Foreground="#616161" />
                    <DataGrid x:Name="CloudAccountsDataGrid"
                              Grid.Row="2"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              MinHeight="260">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Provider"
                                                    SelectedItemBinding="{Binding Provider, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="170" />
                            <DataGridTextColumn Header="Login / account label"
                                                Binding="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                                Width="220" />
                            <DataGridTextColumn Header="Local synced folder"
                                                Binding="{Binding LocalRootPath, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Width="90" Content="Add" Click="OnAddCloudAccountClicked" />
                        <Button Width="90" Margin="10,0,0,0" Content="Remove" Click="OnRemoveCloudAccountClicked" />
                        <Button Width="110" Margin="10,0,0,0" Content="Browse folder" Click="OnBrowseCloudAccountFolderClicked" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Width="90" Margin="0,0,10,0" Content="Cancel" IsCancel="True" />
            <Button Width="90" Content="Save" IsDefault="True" Click="OnSaveClicked" />
        </StackPanel>
    </Grid>
</Window>
