<Window x:Class="UsbFileSync.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:UsbFileSync.Core.Models;assembly=UsbFileSync.Core"
        mc:Ignorable="d"
        Title="USB File Sync"
        Height="560"
        Width="920"
        MinHeight="480"
        MinWidth="760">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="Primary drive" />
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,12" Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="Secondary drive" />
        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,12" Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,12" VerticalAlignment="Center" Text="Mode" />
        <ComboBox Grid.Row="2" Grid.Column="1" Width="160" Margin="0,0,24,12" ItemsSource="{Binding AvailableModes}" SelectedItem="{Binding SelectedMode}">
            <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SyncMode}">
                    <TextBlock Text="{Binding}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <CheckBox Grid.Row="2" Grid.Column="2" Margin="0,0,12,12" VerticalAlignment="Center" Content="Detect moves" IsChecked="{Binding DetectMoves}" />
        <CheckBox Grid.Row="2" Grid.Column="3" Margin="0,0,0,12" VerticalAlignment="Center" Content="Dry run" IsChecked="{Binding DryRun}" />

        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Width="140" Margin="0,0,12,0" Padding="12,6" Command="{Binding AnalyzeCommand}" Content="Preview changes" />
            <Button Width="140" Padding="12,6" Command="{Binding StartSyncCommand}" Content="Run synchronization" />
        </StackPanel>

        <GroupBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Header="Planned actions" Padding="8">
            <DataGrid ItemsSource="{Binding PlannedActions}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Action" Binding="{Binding Type}" Width="170" />
                    <DataGridTextColumn Header="Relative path" Binding="{Binding RelativePath}" Width="*" />
                    <DataGridTextColumn Header="Previous path" Binding="{Binding PreviousRelativePath}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,16,0,0">
            <ProgressBar Height="18" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" />
            <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
