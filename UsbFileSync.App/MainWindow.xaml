<Window x:Class="UsbFileSync.App.MainWindow"
    x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:UsbFileSync.Core.Models;assembly=UsbFileSync.Core"
    xmlns:viewModels="clr-namespace:UsbFileSync.App.ViewModels"
        mc:Ignorable="d"
        Title="USB File Sync"
        Icon="Assets/AppIcon.ico"
        Height="820"
        Width="1380"
        MinHeight="620"
        MinWidth="1120"
        Background="#F3F3F3"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="AccentBrushMuted" Color="#DCEBFA" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#616161" />
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="SectionBackgroundBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="TabBorderBrush" Color="#DADADA" />
        <SolidColorBrush x:Key="TabHoverBrush" Color="#F6F9FC" />
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#F4F4F4" />
        <SolidColorBrush x:Key="DataGridSelectionBrush" Color="#EEF2F5" />
        <SolidColorBrush x:Key="DataGridSelectionBorderBrush" Color="#DCE3E8" />
        <Geometry x:Key="SyncModeChevronGeometry">M0,0 L196,0 L220,22 L196,44 L0,44 L24,22 Z</Geometry>
        <Geometry x:Key="SyncModeBidirectionalGeometry">M24,0 L196,0 L220,22 L196,44 L24,44 L0,22 Z</Geometry>
        <viewModels:PreviewColumnHeader x:Key="PreviewSourceFileHeader" Title="Source File" ColumnKey="SourceFile" />
        <viewModels:PreviewColumnHeader x:Key="PreviewSyncActionHeader" Title="Sync action" ColumnKey="SyncAction" />
        <viewModels:PreviewColumnHeader x:Key="PreviewTransferSpeedHeader" Title="Transfer speed" ColumnKey="TransferSpeed" />
        <viewModels:PreviewColumnHeader x:Key="PreviewDestinationFileHeader" Title="Destination File" ColumnKey="DestinationFile" />
        <viewModels:PreviewColumnHeader x:Key="PreviewFileTypeHeader" Title="File type" ColumnKey="FileType" />
        <viewModels:PreviewColumnHeader x:Key="PreviewSourceSizeHeader" Title="Source size" ColumnKey="SourceSize" />
        <viewModels:PreviewColumnHeader x:Key="PreviewDestinationSizeHeader" Title="Destination size" ColumnKey="DestinationSize" />
        <viewModels:PreviewColumnHeader x:Key="PreviewSourceModifiedHeader" Title="Source Last Modified" ColumnKey="SourceModified" />
        <viewModels:PreviewColumnHeader x:Key="PreviewDestinationModifiedHeader" Title="Destination Last Modified" ColumnKey="DestinationModified" />
        <viewModels:PreviewColumnHeader x:Key="PreviewStatusHeader" Title="Status" ColumnKey="Status" />
        <viewModels:PreviewColumnHeader x:Key="PreviewActionHeader" Title="Action" ColumnKey="Action" />
        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionLabelStyle">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#1F1F1F" />
        </Style>
            <Style TargetType="ToggleButton">
                <Setter Property="Background" Value="#0F6CBD" />
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#0F6CBD" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="MinWidth" Value="110" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,6" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Background" Value="#C42B1C" />
                        <Setter Property="BorderBrush" Value="#C42B1C" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="#CFCFCF" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="#CFCFCF" />
        </Style>
        <Style x:Key="SyncModeComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="Padding" Value="18,6,18,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0" />
                            <DockPanel Margin="20,0,20,0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />
                                  <Path Margin="10,1,0,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Data="M0,0 L6,7 L12,0"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </DockPanel>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        Background="White"
                                        BorderBrush="#CFCFCF"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="240"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Popup" Property="MinHeight" Value="24" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F8F8F8" />
            <Setter Property="HorizontalGridLinesBrush" Value="#ECECEC" />
            <Setter Property="VerticalGridLinesBrush" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#E5E5E5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource DataGridSelectionBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DataGridSelectionBorderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0,8,0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource HeaderTextBrush}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F7F7" />
            <Setter Property="BorderBrush" Value="#E5E5E5" />
            <Setter Property="Foreground" Value="#3B3B3B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="PreviewSelectionColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Padding" Value="8,0,8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="PreviewFilterHeaderButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="MinWidth" Value="18" />
        </Style>
        <Style x:Key="PreviewFilterPopupActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinWidth" Value="72" />
        </Style>
        <Style x:Key="PreviewFilterPopupCompactButtonStyle" TargetType="Button" BasedOn="{StaticResource PreviewFilterPopupActionButtonStyle}">
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <DataTemplate x:Key="PreviewFilterableColumnHeaderTemplate" DataType="{x:Type viewModels:PreviewColumnHeader}">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" />
                <Button Style="{StaticResource PreviewFilterHeaderButtonStyle}"
                        Click="OnPreviewColumnFilterButtonClick"
                        Tag="{Binding}">
                    <TextBlock Text="▾" FontSize="11" VerticalAlignment="Center" />
                </Button>
            </DockPanel>
        </DataTemplate>
        <Style x:Key="CenteredDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ActivityLogTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{Binding ForegroundBrush}" />
        </Style>
        <Style x:Key="ActivityLogMessageTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ActivityLogTextStyle}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Message}" />
            <Setter Property="ToolTipService.ShowDuration" Value="60000" />
        </Style>
        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#ECEFF1" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid SnapsToDevicePixels="True"
                              ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}" CornerRadius="7" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="7" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="0,0,0,10"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              CanContentScroll="False"
                                              Focusable="False">
                                    <StackPanel x:Name="HeaderPanel"
                                                Orientation="Horizontal"
                                                IsItemsHost="True"
                                                Margin="0"
                                                Background="Transparent" />
                                </ScrollViewer>
                            </Border>

                            <Border Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Margin="0"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="{StaticResource TabInactiveBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TabBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#4A4A4A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Border x:Name="SelectionBar"
                                        Height="3"
                                        VerticalAlignment="Bottom"
                                        Background="Transparent"
                                        CornerRadius="0,0,5,5" />
                                <ContentPresenter x:Name="ContentSite"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource TabHoverBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#C7D9EE" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource AccentBrushMuted}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#B7D3F2" />
                                <Setter TargetName="SelectionBar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="PreviewNameCellTemplate">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Cursor="Hand"
                    IsEnabled="{Binding HasSourcePath}"
                    Command="{Binding DataContext.OpenPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open file"
                                  Command="{Binding PlacementTarget.Tag.OpenPreviewFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Open file folder"
                                  Command="{Binding PlacementTarget.Tag.OpenPreviewContainingFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <MenuItem Header="Show comparison"
                                  Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  Click="OnShowComparisonClicked" />
                    </ContextMenu>
                </Button.ContextMenu>
                <Button.Tag>
                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Window}" />
                </Button.Tag>
                <StackPanel Orientation="Horizontal">
                    <Grid Margin="0,0,8,0" Width="16" Height="16" VerticalAlignment="Center">
                        <Image Source="{Binding IconSource}" Stretch="Uniform" Width="16" Height="16" />
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="{Binding IconGlyph}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#5A5A5A">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SourcePath}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                    </Grid>
                    <TextBlock Text="{Binding SourcePath}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               FontWeight="SemiBold"
                               Cursor="Hand"
                               TextDecorations="Underline"
                               Foreground="{Binding SourcePathBrush}" />
                    <TextBlock Margin="8,0,0,0"
                               Text="{Binding SourceStatusGlyph}"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding SourceStatusGlyphBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SourceStatusGlyph}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>
        </DataTemplate>
        <DataTemplate x:Key="PreviewDestinationPathCellTemplate">
            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    Cursor="Hand"
                    IsEnabled="{Binding HasDestinationPath}"
                    Command="{Binding DataContext.OpenDestinationPreviewItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open file"
                                  Command="{Binding PlacementTarget.Tag.OpenDestinationPreviewFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Open file folder"
                                  Command="{Binding PlacementTarget.Tag.OpenDestinationPreviewContainingFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Button.ContextMenu>
                <Button.Tag>
                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Window}" />
                </Button.Tag>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,8,0"
                               Text="{Binding DestinationStatusGlyph}"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{Binding DestinationStatusGlyphBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DestinationStatusGlyph}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding DestinationPath}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               FontWeight="SemiBold"
                               Cursor="Hand"
                               TextDecorations="Underline"
                               Foreground="{Binding DestinationPathBrush}" />
                </StackPanel>
            </Button>
        </DataTemplate>
        <DataTemplate x:Key="PreviewSelectionCellTemplate">
            <CheckBox HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsEnabled="{Binding CanSelect}" />
        </DataTemplate>
        <DataTemplate x:Key="PreviewProgressCellTemplate">
            <Viewbox HorizontalAlignment="Left"
                     Stretch="Uniform"
                     StretchDirection="DownOnly">
                <Grid Width="120" Height="28" Clip="{Binding SyncActionGeometry}">
                    <Rectangle Fill="{Binding SyncActionTrackFillBrush}" />
                    <Rectangle Width="{Binding SyncActionFillWidth}"
                               Fill="{Binding SyncActionBrush}"
                               HorizontalAlignment="Left">
                        <Rectangle.Style>
                            <Style TargetType="Rectangle">
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSourceAction}" Value="True">
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Rectangle.Style>
                    </Rectangle>
                    <Path Data="{Binding SyncActionGeometry}"
                          Stroke="{Binding SyncActionStrokeBrush}"
                          StrokeThickness="1"
                          Fill="Transparent" />
                      <Path Data="{Binding SyncActionTipBorderGeometry}"
                          Stroke="{Binding SyncActionTipBrush}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="Transparent" />
                    <TextBlock Text="{Binding SyncActionDisplayText}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{Binding SyncActionTextBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Grid>
            </Viewbox>
        </DataTemplate>
        <DataTemplate x:Key="PreviewTransferSpeedCellTemplate">
            <TextBlock Text="{Binding TransferSpeedText}"
                       Foreground="#5A5A5A"
                       VerticalAlignment="Center" />
        </DataTemplate>
        <DataTemplate x:Key="PreviewStatusCellTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusGlyph}"
                           Width="16"
                           Margin="0,0,6,0"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{Binding StatusBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Status}"
                           Foreground="{Binding StatusBrush}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="PreviewActionCellTemplate">
            <TextBlock Text="{Binding Action}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#FFFFFF" BorderBrush="#E6E6E6" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="OnExitClicked" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Select All In Tab" Click="OnSelectAllInTabClicked" />
                <MenuItem Header="Select By Pattern..." Click="OnSelectByPatternClicked" />
                <Separator />
                <MenuItem Header="Invert Selection" Click="OnInvertSelectionClicked" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="ToggleInfoBoxesMenuItem" Header="Toggle Info Boxes" IsCheckable="True" IsChecked="True" Click="OnToggleInfoBoxesClicked" />
                <MenuItem Header="Reset Layout" Click="OnResetLayoutClicked" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Application Settings..." Click="OnOpenSettingsClicked" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About UsbFileSync..." Click="OnOpenAboutClicked" />
            </MenuItem>
        </Menu>

        <Popup x:Name="PreviewFilterPopup"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade"
               Closed="OnPreviewFilterPopupClosed">
            <Border x:Name="PreviewFilterPopupBorder"
                    Background="White"
                    BorderBrush="#CFCFCF"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Width="360"
                    Height="440"
                    MinWidth="320"
                    MinHeight="280">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding PreviewFilterTitle, StringFormat=Filter {0}}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource HeaderTextBrush}"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="Sort"
                                   Foreground="{StaticResource SubtleTextBrush}" />
                            <Button Style="{StaticResource PreviewFilterPopupCompactButtonStyle}"
                                FontFamily="Segoe UI Symbol"
                                FontSize="14"
                                Content="↑"
                                    ToolTip="Sort ascending"
                                    Click="OnSortPreviewColumnAscendingClicked" />
                            <Button Style="{StaticResource PreviewFilterPopupCompactButtonStyle}"
                                    Margin="8,0,0,0"
                                FontFamily="Segoe UI Symbol"
                                FontSize="14"
                                Content="↓"
                                    ToolTip="Sort descending"
                                    Click="OnSortPreviewColumnDescendingClicked" />
                        </StackPanel>
                    </Grid>

                    <TextBox x:Name="PreviewFilterSearchTextBox"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             Text="{Binding PreviewFilterSearchText, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Style="{StaticResource PreviewFilterPopupActionButtonStyle}"
                                Content="Select shown"
                                Click="OnSelectVisiblePreviewFilterOptionsClicked" />
                        <Button Style="{StaticResource PreviewFilterPopupActionButtonStyle}"
                                Content="Deselect shown"
                                Click="OnClearVisiblePreviewFilterOptionsClicked" />
                        <Button Style="{StaticResource PreviewFilterPopupActionButtonStyle}"
                            Margin="0,0,0,0"
                                Content="Deselect non-shown"
                                Click="OnDeselectNonShownPreviewFilterOptionsClicked" />
                        </StackPanel>

                    <Border Grid.Row="3"
                            Margin="0,10,0,0"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PreviewFilterOptionsView}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Margin="8,6"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ToolTip="{Binding Value}">
                                            <TextBlock Text="{Binding Value}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Style="{StaticResource PreviewFilterPopupActionButtonStyle}"
                                Content="Clear filter"
                                Click="OnClearPreviewColumnFilterClicked" />
                        <Button Style="{StaticResource PreviewFilterPopupActionButtonStyle}"
                                Content="Apply"
                                Click="OnApplyPreviewColumnFilterClicked" />
                    </StackPanel>

                    <Thumb Grid.Row="5"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Cursor="SizeNWSE"
                           Width="14"
                           Height="14"
                           Margin="0,8,0,0"
                           DragDelta="OnPreviewFilterResizeThumbDragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Grid Width="14" Height="14">
                                    <Path Stroke="#8A8A8A"
                                          StrokeThickness="1"
                                          Data="M3,11 L11,3 M7,11 L11,7 M11,11 L11,11" />
                                </Grid>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>
        </Popup>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SourceLocationColumnDefinition" Width="1.25*" />
                    <ColumnDefinition x:Name="SyncSettingsColumnDefinition" Width="400" />
                    <ColumnDefinition x:Name="DestinationLocationColumnDefinition" Width="1.25*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="SOURCE LOCATION" />
                        <TextBlock Text="Source drive" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource HeaderTextBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SourcePathTextBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Text="{Binding SourcePathDisplayText, Mode=OneWay}"
                                     ToolTip="{Binding SourcePath}"
                                     GotKeyboardFocus="OnSourcePathTextBoxGotKeyboardFocus"
                                     LostKeyboardFocus="OnSourcePathTextBoxLostKeyboardFocus" />
                            <Button Grid.Column="1" Margin="10,8,0,0" Padding="14,7" Command="{Binding BrowseSourcePathCommand}" Content="Browse..." />
                        </Grid>
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="{Binding SourceLocationDescription}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="18" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="SYNC SETTINGS" />
                        <Grid Margin="0,4,0,0" HorizontalAlignment="Center">
                            <Grid Width="220"
                                  Height="44"
                                  HorizontalAlignment="Center">
                                <Path Fill="{StaticResource AccentBrushMuted}">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource SyncModeChevronGeometry}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:SyncMode.TwoWay}">
                                                    <Setter Property="Data" Value="{StaticResource SyncModeBidirectionalGeometry}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Fill="Transparent"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource SyncModeChevronGeometry}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static models:SyncMode.TwoWay}">
                                                    <Setter Property="Data" Value="{StaticResource SyncModeBidirectionalGeometry}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <ComboBox Style="{StaticResource SyncModeComboBoxStyle}"
                                          Width="220"
                                          HorizontalAlignment="Center"
                                          ItemsSource="{Binding AvailableModes}"
                                          SelectedItem="{Binding SelectedMode}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:SyncMode}">
                                            <TextBlock Text="{Binding}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Grid>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Content="Detect moves"
                                      IsEnabled="{Binding IsDetectMovesAvailable}"
                                      IsChecked="{Binding DetectMoves}"
                                      ToolTip="One-way mode only. Treat matching delete-and-create changes as a rename or move when the file content appears to be the same." />
                            <CheckBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Content="Dry run"
                                      IsChecked="{Binding DryRun}"
                                      ToolTip="Preview the planned synchronization actions without copying, overwriting, deleting, or creating files and folders." />
                            <CheckBox Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Content="Checksums"
                                      IsChecked="{Binding VerifyChecksums}"
                                      ToolTip="Calculate SHA-256 checksums for the source and copied file before committing each transfer. This improves integrity validation but makes transfers slower." />
                            <CheckBox Grid.Column="3"
                                      VerticalAlignment="Center"
                                      Content="Move Mode"
                                      IsChecked="{Binding MoveMode}"
                                      ToolTip="After each copy or overwrite completes, UsbFileSync validates the copied file with SHA-256 and deletes the original only when the source and destination hashes match. This is intended for move-style transfer workflows." />
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" HorizontalAlignment="Stretch" Command="{Binding AnalyzeCommand}" Content="Analyze" />
                            <ToggleButton Grid.Column="2"
                                          HorizontalAlignment="Stretch"
                                          IsChecked="{Binding IsSyncRunning, Mode=OneWay}"
                                          Command="{Binding ToggleSyncCommand}"
                                          Content="{Binding SyncButtonText}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabelStyle}" Text="DESTINATION LOCATION" />
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Destination drive"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource HeaderTextBrush}"
                                       VerticalAlignment="Center" />
                            <Button Margin="10,0,0,0"
                                    Padding="10,4"
                                    VerticalAlignment="Center"
                                    Background="#E8F5E9"
                                    BorderBrush="#7CB342"
                                    Foreground="#1B5E20"
                                    FontWeight="Bold"
                                    Command="{Binding AddDestinationPathCommand}"
                                    ToolTip="Add another destination drive or folder"
                                    Content="+" />
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="DestinationPathTextBox"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     Text="{Binding DestinationPathDisplayText, Mode=OneWay}"
                                     ToolTip="{Binding DestinationPath}"
                                     GotKeyboardFocus="OnDestinationPathTextBoxGotKeyboardFocus"
                                     LostKeyboardFocus="OnDestinationPathTextBoxLostKeyboardFocus" />
                             <Button Grid.Column="1" Margin="10,8,0,0" Padding="14,7" Command="{Binding BrowseDestinationPathCommand}" Content="Browse..." />
                         </Grid>
                        <ItemsControl Margin="0,8,0,0"
                                      ItemsSource="{Binding AdditionalDestinationPaths}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Margin="0,8,10,0"
                                                Padding="10,7"
                                            Background="#FDECEC"
                                            BorderBrush="#D13438"
                                            Foreground="#A4262C"
                                            FontWeight="Bold"
                                                Command="{Binding DataContext.RemoveDestinationPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove this destination"
                                                Content="×" />
                                        <TextBox Grid.Column="1"
                                                 IsReadOnly="True"
                                                 Text="{Binding DisplayText, Mode=OneWay}"
                                                 ToolTip="{Binding Path}"
                                                 GotKeyboardFocus="OnAdditionalDestinationPathTextBoxGotKeyboardFocus"
                                                 LostKeyboardFocus="OnAdditionalDestinationPathTextBoxLostKeyboardFocus" />
                                        <Button Grid.Column="2"
                                                Margin="10,8,0,0"
                                                Padding="14,7"
                                                Command="{Binding DataContext.BrowseDestinationPathCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Content="Browse..." />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="{Binding DestinationLocationDescription}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="PreviewPaneRowDefinition" Height="*" MinHeight="280" />
                    <RowDefinition x:Name="DashboardSplitterRowDefinition" Height="12" />
                    <RowDefinition x:Name="DashboardRowDefinition" Height="220" MinHeight="170" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="16" MinHeight="280">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Synchronization preview" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource HeaderTextBrush}" />
                            <TextBlock Margin="0,6,0,0" Text="Use the tabs to filter the preview table by new, changed, deleted, unchanged, or all items." Foreground="{StaticResource SubtleTextBrush}" />
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <TabControl x:Name="PreviewTabControl">
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+"
                                                   Margin="0,0,6,0"
                                                   FontWeight="Bold"
                                                   Foreground="#128C44" />
                                        <TextBlock Text="{Binding NewFilesCount, StringFormat=New Files ({0})}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DataGrid ItemsSource="{Binding NewFiles}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="36" CellTemplate="{StaticResource PreviewSelectionCellTemplate}" HeaderStyle="{StaticResource PreviewSelectionColumnHeaderStyle}">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsThreeState="True"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding DataContext.AreAllNewFilesSelected, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSourceFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewNameCellTemplate}" Width="400" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSyncActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewProgressCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewTransferSpeedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewTransferSpeedCellTemplate}" Width="110" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewDestinationFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewDestinationPathCellTemplate}" Width="220" />
                                        <DataGridTextColumn Header="{StaticResource PreviewFileTypeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding FileType}" Width="90" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewStatusHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewStatusCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewActionCellTemplate}" Width="210" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✎"
                                                   Margin="0,0,6,0"
                                                   FontWeight="Bold"
                                                   Foreground="#B87D00" />
                                        <TextBlock Text="{Binding ChangedFilesCount, StringFormat=Changed ({0})}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DataGrid ItemsSource="{Binding ChangedFiles}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="36" CellTemplate="{StaticResource PreviewSelectionCellTemplate}" HeaderStyle="{StaticResource PreviewSelectionColumnHeaderStyle}">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsThreeState="True"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding DataContext.AreAllChangedFilesSelected, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSourceFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewNameCellTemplate}" Width="400" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSyncActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewProgressCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewTransferSpeedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewTransferSpeedCellTemplate}" Width="110" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewDestinationFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewDestinationPathCellTemplate}" Width="220" />
                                        <DataGridTextColumn Header="{StaticResource PreviewFileTypeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding FileType}" Width="90" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewStatusHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewStatusCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewActionCellTemplate}" Width="210" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="×"
                                                   Margin="0,0,6,0"
                                                   FontWeight="Bold"
                                                   Foreground="#C42B1C" />
                                        <TextBlock Text="{Binding DeletedFilesCount, StringFormat=Deleted ({0})}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DataGrid ItemsSource="{Binding DeletedFiles}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="36" CellTemplate="{StaticResource PreviewSelectionCellTemplate}" HeaderStyle="{StaticResource PreviewSelectionColumnHeaderStyle}">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsThreeState="True"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding DataContext.AreAllDeletedFilesSelected, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSourceFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewNameCellTemplate}" Width="400" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSyncActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewProgressCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewTransferSpeedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewTransferSpeedCellTemplate}" Width="110" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewDestinationFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewDestinationPathCellTemplate}" Width="220" />
                                        <DataGridTextColumn Header="{StaticResource PreviewFileTypeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding FileType}" Width="90" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewStatusHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewStatusCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewActionCellTemplate}" Width="210" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="||"
                                                   Margin="0,0,6,0"
                                                   FontWeight="Bold"
                                                   Foreground="#626262" />
                                        <TextBlock Text="{Binding UnchangedFilesCount, StringFormat=Unchanged ({0})}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DataGrid ItemsSource="{Binding UnchangedFiles}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="36" CellTemplate="{StaticResource PreviewSelectionCellTemplate}" HeaderStyle="{StaticResource PreviewSelectionColumnHeaderStyle}">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsThreeState="True"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding DataContext.AreAllUnchangedFilesSelected, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSourceFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewNameCellTemplate}" Width="400" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSyncActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewProgressCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewTransferSpeedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewTransferSpeedCellTemplate}" Width="110" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewDestinationFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewDestinationPathCellTemplate}" Width="220" />
                                        <DataGridTextColumn Header="{StaticResource PreviewFileTypeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding FileType}" Width="90" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewStatusHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewStatusCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewActionCellTemplate}" Width="210" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="•"
                                                   Margin="0,0,6,0"
                                                   FontWeight="Bold"
                                                   Foreground="#5A5A5A" />
                                        <TextBlock Text="{Binding AllFilesCount, StringFormat=All ({0})}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DataGrid ItemsSource="{Binding AllFiles}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="36" CellTemplate="{StaticResource PreviewSelectionCellTemplate}" HeaderStyle="{StaticResource PreviewSelectionColumnHeaderStyle}">
                                            <DataGridTemplateColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsThreeState="True"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding DataContext.AreAllFilesSelected, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.HeaderTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSourceFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewNameCellTemplate}" Width="400" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewSyncActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewProgressCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewTransferSpeedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewTransferSpeedCellTemplate}" Width="110" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewDestinationFileHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewDestinationPathCellTemplate}" Width="220" />
                                        <DataGridTextColumn Header="{StaticResource PreviewFileTypeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding FileType}" Width="90" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationSizeHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationSize}" Width="95" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewSourceModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding SourceModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTextColumn Header="{StaticResource PreviewDestinationModifiedHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" Binding="{Binding DestinationModified}" Width="150" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewStatusHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewStatusCellTemplate}" Width="140" />
                                        <DataGridTemplateColumn Header="{StaticResource PreviewActionHeader}" HeaderTemplate="{StaticResource PreviewFilterableColumnHeaderTemplate}" CellTemplate="{StaticResource PreviewActionCellTemplate}" Width="210" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            </TabControl>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter x:Name="PreviewDashboardGridSplitter" Grid.Row="1"
                          Height="2"
                          Margin="0,5,0,5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                              Background="{StaticResource CardBorderBrush}" />

                <Grid x:Name="InfoBoxesGrid" Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="QueueColumnDefinition" Width="*" MinWidth="260" />
                        <ColumnDefinition x:Name="InfoBoxesSplitterColumnDefinition" Width="12" />
                        <ColumnDefinition x:Name="ActivityColumnDefinition" Width="*" MinWidth="320" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="0,0,6,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Remaining queue" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource HeaderTextBrush}" />
                            <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="{Binding QueueSummary}" Foreground="{StaticResource SubtleTextBrush}" />
                            <ProgressBar Grid.Row="2"
                                         Margin="0,8,0,0"
                                         Height="18"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding ProgressValue, Mode=OneWay}"
                                         Foreground="{StaticResource AccentBrush}"
                                         Style="{StaticResource RoundedProgressBarStyle}" />
                            <DataGrid Grid.Row="3" Margin="0,12,0,0" MinHeight="110" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{Binding RemainingQueue}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="170" />
                                    <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="2"
                                  Margin="0"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True"
                                  Background="{StaticResource CardBorderBrush}" />

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="16" Margin="6,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Activity log" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource HeaderTextBrush}" />
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <RadioButton Content="All"
                                             Margin="0,0,14,0"
                                             IsChecked="{Binding ShowAllActivityLog}" />
                                <RadioButton Content="Warnings / Errors"
                                             Margin="0,0,14,0"
                                             IsChecked="{Binding ShowAlertsOnlyActivityLog}" />
                                <RadioButton Content="Verbose"
                                             IsChecked="{Binding ShowVerboseOnlyActivityLog}" />
                            </StackPanel>
                            <DataGrid Grid.Row="2" Margin="0,12,0,0" MinHeight="110" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{Binding ActivityLogView}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90" ElementStyle="{StaticResource ActivityLogTextStyle}" />
                                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="120" ElementStyle="{StaticResource ActivityLogTextStyle}" />
                                    <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" ElementStyle="{StaticResource ActivityLogMessageTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="14,10">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                        <Setter Property="Background" Value="#FFF7E6" />
                        <Setter Property="BorderBrush" Value="#E6C98F" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                <Setter Property="Background" Value="#E8F5E9" />
                                <Setter Property="BorderBrush" Value="#96D4A0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#5F4200" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="#1E5E2E" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <Border Grid.RowSpan="3"
                    Background="#CCFFFFFF"
                    Visibility="{Binding IsBusyOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Panel.ZIndex="20">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="420"
                        Padding="30,24"
                        Background="#FFFFFF"
                        BorderBrush="#D9E4EE"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <ProgressBar Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     IsIndeterminate="{Binding IsBusyOverlayProgressIndeterminate}"
                                     Value="{Binding BusyOverlayProgressValue, Mode=OneWay}" />
                        <TextBlock Margin="0,16,0,0"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding BusyOverlayTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource HeaderTextBrush}" />
                        <TextBlock Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding BusyOverlayDescription}"
                                   Foreground="{StaticResource SubtleTextBrush}" />
                        <TextBlock Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               MaxWidth="520"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding BusyOverlayCountersText}"
                               Foreground="{StaticResource SubtleTextBrush}" />
                           <TextBlock Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               MaxWidth="520"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding BusyOverlayPathText}"
                               Foreground="{StaticResource SubtleTextBrush}" />
                        <TextBlock Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               MaxWidth="520"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding BusyOverlayEtaText}"
                               Foreground="{StaticResource SubtleTextBrush}" />
                        <StackPanel Margin="0,18,0,0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                            <Button Width="170"
                                Margin="0,0,10,0"
                                Visibility="{Binding IsUseCompletedAnalyzeResultsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Command="{Binding UseCompletedAnalyzeResultsCommand}"
                                Content="Use completed results" />
                            <Button Width="110"
                                Command="{Binding CancelBusyOperationCommand}"
                                Content="Cancel" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</Window>
